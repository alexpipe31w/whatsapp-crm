generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  storeId     String   @id @default(uuid()) @map("store_id")
  name        String   @db.VarChar(100)
  phone       String   @unique @db.VarChar(20)
  ownerName   String?  @map("owner_name") @db.VarChar(100)
  waSessionId String?  @unique @map("wa_session_id") @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customers     Customer[]
  conversations Conversation[]
  messages      Message[]
  products      Product[]
  services      Service[]
  orders        Order[]
  campaigns     Campaign[]
  aiConfig      AIConfiguration?

  @@map("stores")
}

model Customer {
  customerId String   @id @default(uuid()) @map("customer_id")
  storeId    String   @map("store_id")
  phone      String   @db.VarChar(20)
  name       String?  @db.VarChar(100)
  city       String?  @db.VarChar(100) // ✅ nuevo campo
  createdAt  DateTime @default(now()) @map("created_at")

  store         Store          @relation(fields: [storeId], references: [storeId], onDelete: Cascade)
  conversations Conversation[]
  orders        Order[]

  @@unique([storeId, phone])
  @@map("customers")
}

model Conversation {
  conversationId String   @id @default(uuid()) @map("conversation_id")
  storeId        String   @map("store_id")
  customerId     String   @map("customer_id")
  status         String   @default("active")
  startedAt      DateTime @default(now()) @map("started_at")
  lastMessageAt  DateTime @default(now()) @map("last_message_at")
  createdAt      DateTime @default(now()) @map("created_at")

  store    Store    @relation(fields: [storeId], references: [storeId])
  customer Customer @relation(fields: [customerId], references: [customerId])
  messages Message[]

  @@map("conversations")
}

model Message {
  messageId      String   @id @default(uuid()) @map("message_id")
  conversationId String   @map("conversation_id")
  storeId        String   @map("store_id")
  content        String
  type           String
  sender         String   @default("customer")
  isAiResponse   Boolean  @default(false) @map("is_ai_response")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [conversationId])
  store        Store        @relation(fields: [storeId], references: [storeId])

  @@map("messages")
}

model Product {
  productId   String   @id @default(uuid()) @map("product_id")
  storeId     String   @map("store_id")
  sku         String?  @db.VarChar(100)
  name        String   @db.VarChar(200)
  costPrice   Decimal  @map("cost_price") @db.Decimal(10, 2) // precio base
  salePrice   Decimal  @map("sale_price") @db.Decimal(10, 2) // precio base
  stock       Int      @default(0)                            // stock base (sin variantes)
  description String?
  imageUrl    String?  @map("image_url")
  hasShipping Boolean  @default(false) @map("has_shipping")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  store      Store            @relation(fields: [storeId], references: [storeId])
  orderItems OrderItem[]
  variants   ProductVariant[]

  @@unique([storeId, sku])
  @@map("products")
}

// Cada variante de un producto tiene su propio precio y stock
model ProductVariant {
  variantId  String  @id @default(uuid()) @map("variant_id")
  productId  String  @map("product_id")
  name       String  @db.VarChar(200)   // Ej: "Talla M / Rojo"
  sku        String? @db.VarChar(100)
  costPrice  Decimal @map("cost_price") @db.Decimal(10, 2)
  salePrice  Decimal @map("sale_price") @db.Decimal(10, 2)
  stock      Int     @default(0)
  isActive   Boolean @default(true) @map("is_active")

  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@map("product_variants")
}

model Service {
  serviceId   String   @id @default(uuid()) @map("service_id")
  storeId     String   @map("store_id")
  name        String   @db.VarChar(200)
  description String?
  price       Decimal? @db.Decimal(10, 2)
  duration    Int?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  store      Store       @relation(fields: [storeId], references: [storeId])
  orderItems OrderItem[]

  @@map("services")
}

model Order {
  orderId         String   @id @default(uuid()) @map("order_id")
  storeId         String   @map("store_id")
  customerId      String   @map("customer_id")
  type            String   @default("product")           // 'product' | 'food' | 'service'
  total           Decimal  @default(0) @db.Decimal(10, 2)
  status          String   @default("pending")           // pending | confirmed | preparing | ready | delivered | cancelled
  notes           String?
  estimatedTime   Int?     @map("estimated_time")        // minutos
  deliveryAddress String?  @map("delivery_address")
  createdAt       DateTime @default(now()) @map("created_at")

  store      Store       @relation(fields: [storeId], references: [storeId])
  customer   Customer    @relation(fields: [customerId], references: [customerId])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  itemId      String  @id @default(uuid()) @map("item_id")
  orderId     String  @map("order_id")
  productId   String? @map("product_id")
  serviceId   String? @map("service_id")
  description String? // ítem libre sin producto/servicio en BD
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [productId])
  service Service? @relation(fields: [serviceId], references: [serviceId])

  @@map("order_items")
}

model AIConfiguration {
  configId     String  @id @default(uuid()) @map("config_id")
  storeId      String  @unique @map("store_id")
  groqApiKey   String  @map("groq_api_key")
  systemPrompt String  @map("system_prompt")
  model        String  @default("llama-3.3-70b-versatile")
  temperature  Decimal @default(0.70) @db.Decimal(3, 2)
  maxTokens    Int     @default(1024) @map("max_tokens")
  settings     Json    @default("{}")

  store Store @relation(fields: [storeId], references: [storeId])

  @@map("ai_configurations")
}

model Campaign {
  campaignId  String    @id @default(uuid()) @map("campaign_id")
  storeId     String    @map("store_id")
  name        String    @db.VarChar(200)
  message     String
  status      String    @default("draft")
  sentCount   Int       @default(0) @map("sent_count")
  scheduledAt DateTime? @map("scheduled_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  store Store @relation(fields: [storeId], references: [storeId])

  @@map("campaigns")
}

model User {
  userId    String   @id @default(uuid()) @map("user_id")
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(200)
  password  String
  role      String   @default("admin")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
