generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  storeId     String   @id @default(uuid()) @map("store_id")
  name        String   @db.VarChar(100)
  phone       String   @unique @db.VarChar(20)
  ownerName   String?  @map("owner_name") @db.VarChar(100)
  waSessionId String?  @unique @map("wa_session_id") @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customers       Customer[]
  conversations   Conversation[]
  messages        Message[]
  products        Product[]
  users           User[]
  services        Service[]
  orders          Order[]
  appointments    Appointment[]
  campaigns       Campaign[]
  aiConfig        AIConfiguration?
  blockedContacts BlockedContact[]
  waSession       WhatsappSession?

  @@map("stores")
}

model Customer {
  customerId String   @id @default(uuid()) @map("customer_id")
  storeId    String   @map("store_id")
  phone      String   @db.VarChar(20)
  name       String?  @db.VarChar(100)
  cedula     String?  @db.VarChar(20)
  city       String?  @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  store         Store          @relation(fields: [storeId], references: [storeId], onDelete: Cascade)
  conversations Conversation[]
  orders        Order[]
  appointments  Appointment[]

  @@unique([storeId, phone])
  @@index([storeId, createdAt])
  @@map("customers")
}

model Conversation {
  conversationId String   @id @default(uuid()) @map("conversation_id")
  storeId        String   @map("store_id")
  customerId     String   @map("customer_id")
  status         String   @default("active")
  startedAt      DateTime @default(now()) @map("started_at")
  lastMessageAt  DateTime @default(now()) @map("last_message_at")
  createdAt      DateTime @default(now()) @map("created_at")

  store    Store    @relation(fields: [storeId], references: [storeId])
  customer Customer @relation(fields: [customerId], references: [customerId])
  messages Message[]

  @@index([storeId, status])
  @@index([customerId, status])
  @@map("conversations")
}

model Message {
  messageId      String   @id @default(uuid()) @map("message_id")
  conversationId String   @map("conversation_id")
  storeId        String   @map("store_id")
  content        String
  type           String
  sender         String   @default("customer")
  isAiResponse   Boolean  @default(false) @map("is_ai_response")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [conversationId])
  store        Store        @relation(fields: [storeId], references: [storeId])

  @@index([conversationId, createdAt])
  @@index([storeId, createdAt])
  @@map("messages")
}

model Product {
  productId   String   @id @default(uuid()) @map("product_id")
  storeId     String   @map("store_id")
  sku         String?  @db.VarChar(100)
  name        String   @db.VarChar(200)
  costPrice   Decimal  @map("cost_price") @db.Decimal(10, 2)
  salePrice   Decimal  @map("sale_price") @db.Decimal(10, 2)
  stock       Int      @default(0)
  description String?
  imageUrl    String?  @map("image_url")
  hasShipping Boolean  @default(false) @map("has_shipping")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store      Store            @relation(fields: [storeId], references: [storeId])
  orderItems OrderItem[]
  variants   ProductVariant[]

  @@unique([storeId, sku])
  @@index([storeId, isActive])
  @@map("products")
}

model ProductVariant {
  variantId  String  @id @default(uuid()) @map("variant_id")
  productId  String  @map("product_id")
  name       String  @db.VarChar(200)
  sku        String? @db.VarChar(100)
  costPrice  Decimal @map("cost_price") @db.Decimal(10, 2)
  salePrice  Decimal @map("sale_price") @db.Decimal(10, 2)
  stock      Int     @default(0)
  isActive   Boolean @default(true) @map("is_active")

  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@map("product_variants")
}

model Service {
  serviceId   String   @id @default(uuid()) @map("service_id")
  storeId     String   @map("store_id")
  name        String   @db.VarChar(200)
  description String?
  price       Decimal? @db.Decimal(10, 2)
  duration    Int?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  store      Store       @relation(fields: [storeId], references: [storeId])
  orderItems OrderItem[]

  @@map("services")
}

model Order {
  orderId         String   @id @default(uuid()) @map("order_id")
  storeId         String   @map("store_id")
  customerId      String   @map("customer_id")
  type            String   @default("product")
  total           Decimal  @default(0) @db.Decimal(10, 2)
  status          String   @default("pending")
  notes           String?
  estimatedTime   Int?     @map("estimated_time")
  deliveryAddress String?  @map("delivery_address")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  store      Store       @relation(fields: [storeId], references: [storeId])
  customer   Customer    @relation(fields: [customerId], references: [customerId])
  orderItems OrderItem[]

  @@index([storeId, status])
  @@index([storeId, createdAt])
  @@map("orders")
}

model OrderItem {
  itemId      String  @id @default(uuid()) @map("item_id")
  orderId     String  @map("order_id")
  productId   String? @map("product_id")
  serviceId   String? @map("service_id")
  description String?
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [productId])
  service Service? @relation(fields: [serviceId], references: [serviceId])

  @@map("order_items")
}

// ─── Agendamientos / Citas ────────────────────────────────────────────────────
// Maneja citas, visitas técnicas y cualquier tipo de agendamiento.
// La IA crea estos registros automáticamente cuando detecta intención de agendar.
model Appointment {
  appointmentId String   @id @default(uuid()) @map("appointment_id")
  storeId       String   @map("store_id")
  customerId    String   @map("customer_id")
  // tipo: "cita" | "visita_tecnica" | "otro"
  type          String   @default("cita")
  scheduledAt   DateTime @map("scheduled_at")
  description   String?
  address       String?
  // status: "pending" | "confirmed" | "completed" | "cancelled"
  status        String   @default("pending")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  store    Store    @relation(fields: [storeId], references: [storeId])
  customer Customer @relation(fields: [customerId], references: [customerId])

  @@index([storeId, scheduledAt])
  @@index([storeId, status])
  @@index([customerId])
  @@map("appointments")
}

model AIConfiguration {
  configId     String  @id @default(uuid()) @map("config_id")
  storeId      String  @unique @map("store_id")
  groqApiKey   String  @map("groq_api_key")
  systemPrompt String  @map("system_prompt")
  model        String  @default("llama-3.3-70b-versatile")
  temperature  Decimal @default(0.70) @db.Decimal(3, 2)
  maxTokens    Int     @default(1024) @map("max_tokens")
  settings     Json    @default("{}")

  store Store @relation(fields: [storeId], references: [storeId])

  @@map("ai_configurations")
}

model Campaign {
  campaignId  String    @id @default(uuid()) @map("campaign_id")
  storeId     String    @map("store_id")
  name        String    @db.VarChar(200)
  message     String
  status      String    @default("draft")
  sentCount   Int       @default(0) @map("sent_count")
  scheduledAt DateTime? @map("scheduled_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  store Store @relation(fields: [storeId], references: [storeId])

  @@map("campaigns")
}

model User {
  userId    String   @id @default(uuid()) @map("user_id")
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(200)
  password  String
  role      String   @default("admin")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  storeId   String?  @map("store_id")

  store Store? @relation(fields: [storeId], references: [storeId])

  @@map("users")
}

model BlockedContact {
  blockedId String   @id @default(uuid()) @map("blocked_id")
  storeId   String   @map("store_id")
  phone     String   @db.VarChar(20)
  label     String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  store Store @relation(fields: [storeId], references: [storeId], onDelete: Cascade)

  @@unique([storeId, phone])
  @@map("blocked_contacts")
}

model WhatsappSession {
  storeId   String   @id @map("store_id")
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  store Store @relation(fields: [storeId], references: [storeId], onDelete: Cascade)

  @@map("whatsapp_sessions")
}
